# === Production Environment Variables ===
# Copy this file to .env and fill in real values

# Domain
DOMAIN=crm.example.com

# PostgreSQL
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=crm_db

# RabbitMQ
RABBITMQ_USER=crm_rabbit
RABBITMQ_PASS=CHANGE_ME_RABBIT_PASSWORD

# S3 / MinIO
S3_ACCESS_KEY=CHANGE_ME_S3_KEY
S3_SECRET_KEY=CHANGE_ME_S3_SECRET
S3_BUCKET=crm-files

# App secrets (backend/.env)
SECRET_KEY=CHANGE_ME_RANDOM_64_CHARS
OPENAI_API_KEY=xai-your-key-here
OPENAI_MODEL=grok-3-mini
AI_BASE_URL=https://api.x.ai/v1

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
