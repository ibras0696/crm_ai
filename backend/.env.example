# ============================================================
# CRM Platform — полный пример переменных окружения
# Скопируйте в backend/.env и заполните значения
# ============================================================

# --- База данных PostgreSQL ---
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_secure_password_here
POSTGRES_DB=crm_db
DATABASE_URL=postgresql+asyncpg://crm_user:crm_secure_password_here@db:5432/crm_db
DATABASE_URL_SYNC=postgresql+psycopg2://crm_user:crm_secure_password_here@db:5432/crm_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- RabbitMQ ---
RABBITMQ_URL=amqp://crm_rabbit:crm_rabbit_pass@rabbitmq:5672/
RABBITMQ_USER=crm_rabbit
RABBITMQ_PASS=crm_rabbit_pass

# --- JWT / Безопасность ---
SECRET_KEY=your-super-secret-jwt-key-min-32-chars-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- AI (Timeweb Agent / OpenAI-совместимый) ---
# Основной токен для Authorization: Bearer <token>
OPENAI_BEARER_TOKEN=your-timeweb-bearer-token
# Fallback для старых провайдеров (можно оставить пустым)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
AI_BASE_URL=https://agent.timeweb.cloud/api/v1/cloud-ai/agents/289156bc-4adc-4be8-94cf-6767a704a80c/v1
AI_SYSTEM_PROMPT=Ты — AI-ассистент CRM платформы. Отвечай на русском языке. Помогай с данными, отчётами и аналитикой.

# --- MinIO / S3 ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_secret
S3_BUCKET=crm-files
S3_REGION=us-east-1

# --- SMTP (Gmail) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password-16-chars
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=CRM Platform
SMTP_TLS=true

# --- Домен и CORS ---
DOMAIN=example.com
CORS_ORIGINS=["http://localhost:5173","https://example.com"]
FRONTEND_URL=https://example.com

# --- Приложение ---
APP_NAME=CRM Platform
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=production

# --- ЮКасса (YooKassa) ---
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-yookassa-secret-key
YOOKASSA_RETURN_URL=https://example.com/billing/success

# --- Grafana ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafana_secure_password

# --- Certbot / SSL ---
CERTBOT_EMAIL=admin@example.com
