# Secrets override для Docker Compose.
#
# Зачем файл:
# - чтобы секреты не лежали в `.env` и не светились в репозитории
# - compose умеет мерджить несколько YAML файлов: это официальный механизм
#
# Как использовать:
# 1) Скопируй `secrets.yml.example` -> `secrets.yml`
# 2) Заполни значения (НЕ коммить `secrets.yml`)
# 3) Запускай compose с двумя файлами:
#    - Dev:  docker compose -f docker-compose.yml -f secrets.yml up -d
#    - Prod: docker compose -f docker-compose.prod.yml -f secrets.yml up -d
#
# Важно:
# - Ниже перечислены основные ключи, которые использует backend (см. `backend/src/config.py`)
#   и docker-compose (см. `docker-compose*.yml`), чтобы не было рассинхрона.
# - Ты можешь заполнять только нужные, остальные оставить пустыми/по умолчанию.
services:
  # --- Database (PostgreSQL) ---
  db:
    environment:
      # DEV default
      POSTGRES_USER: "CHANGE_ME_DB_USER"
      POSTGRES_PASSWORD: "CHANGE_ME_DB_PASSWORD"
      POSTGRES_DB: "crm_db"
  # --- Message broker (RabbitMQ) ---
  rabbitmq:
    environment:
      # Реальные переменные RabbitMQ
      # DEV default
      RABBITMQ_DEFAULT_USER: "CHANGE_ME_RABBIT_USER"
      RABBITMQ_DEFAULT_PASS: "CHANGE_ME_RABBIT_PASSWORD"
      # Для унификации с backend/config (сам RabbitMQ их не использует)
      RABBITMQ_USER: "CHANGE_ME_RABBIT_USER"
      RABBITMQ_PASS: "CHANGE_ME_RABBIT_PASSWORD"
  # --- Object storage (S3/MinIO) ---
  minio:
    environment:
      # DEV default
      MINIO_ROOT_USER: "CHANGE_ME_S3_ACCESS_KEY"
      MINIO_ROOT_PASSWORD: "CHANGE_ME_S3_SECRET_KEY"
  # --- Backend ---
  api:
    environment:
      # --- Feature flags ---
      # В dev по умолчанию выключаем AI, чтобы не требовать токен при старте.
      ENABLE_AI: "false"
      ENABLE_SENTRY: "false"
      ENABLE_METRICS: "true"
      ENABLE_RATE_LIMIT: "true"

      # --- Домен и URL ---
      DOMAIN: "crm.example.com"
      FRONTEND_URL: "https://crm.example.com"
      CORS_ORIGINS: "[\"http://localhost:5173\",\"https://crm.example.com\"]"

      # --- PostgreSQL ---
      # DEV default
      POSTGRES_USER: "CHANGE_ME_DB_USER"
      POSTGRES_PASSWORD: "CHANGE_ME_DB_PASSWORD"
      POSTGRES_DB: "crm_db"
      DATABASE_URL: "postgresql+asyncpg://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@db:5432/crm_db"
      DATABASE_URL_SYNC: "postgresql+psycopg2://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@db:5432/crm_db"
      DB_POOL_SIZE: "20"
      DB_MAX_OVERFLOW: "10"
      DB_POOL_TIMEOUT_S: "30"
      DB_POOL_RECYCLE_S: "1800"
      DB_HEALTH_TIMEOUT_S: "2"

      # --- Redis ---
      REDIS_URL: "redis://redis:6379/0"
      REDIS_HEALTH_TIMEOUT_S: "2"

      # --- RabbitMQ ---
      # DEV default
      RABBITMQ_USER: "CHANGE_ME_RABBIT_USER"
      RABBITMQ_PASS: "CHANGE_ME_RABBIT_PASSWORD"
      RABBITMQ_URL: "amqp://CHANGE_ME_RABBIT_USER:CHANGE_ME_RABBIT_PASSWORD@rabbitmq:5672/"

      # --- S3 / MinIO ---
      S3_ENDPOINT: "http://minio:9000"
      # DEV default
      S3_ACCESS_KEY: "CHANGE_ME_S3_ACCESS_KEY"
      S3_SECRET_KEY: "CHANGE_ME_S3_SECRET_KEY"
      S3_BUCKET: "crm-files"
      S3_REGION: "us-east-1"
      S3_FORCE_PATH_STYLE: "true"
      S3_VERIFY_SSL: "true"
      S3_USE_SSL: "false"

      # --- Приложение / Безопасность ---
      APP_NAME: "CRM Platform"
      # DEV default (>= 32 chars)
      SECRET_KEY: "CHANGE_ME_SECRET_KEY_MIN_32"
      JWT_ALGORITHM: "HS256"
      ACCESS_TOKEN_EXPIRE_MINUTES: "30"
      REFRESH_TOKEN_EXPIRE_DAYS: "7"

      DEBUG: "true"
      LOG_LEVEL: "INFO"
      ENVIRONMENT: "development"

      # --- Sentry ---
      SENTRY_DSN: ""

      # --- AI (Timeweb Agent / OpenAI-совместимый) ---
      OPENAI_BEARER_TOKEN: ""
      OPENAI_API_KEY: ""
      OPENAI_MODEL: "gpt-4.1"
      AI_BASE_URL: "https://agent.timeweb.cloud/api/v1/cloud-ai/agents/289156bc-4adc-4be8-94cf-6767a704a80c/v1"
      # Legacy (оставлено для обратной совместимости; лучше использовать *_PER_REQUEST)
      AI_MAX_TOKENS: "6000"
      AI_MAX_TOKENS_PER_REQUEST: "2000"
      AI_MAX_TOKENS_PER_DAY_PER_ORG: "200000"
      AI_RPM_PER_USER: "30"
      AI_SYSTEM_PROMPT: "You are an AI assistant for the CRM platform. Reply in Russian."

      # Billing (YooKassa)
      YOOKASSA_SHOP_ID: ""
      YOOKASSA_SECRET_KEY: ""
      YOOKASSA_RETURN_URL: "https://crm.example.com/billing/success"

      # SMTP
      SMTP_HOST: "smtp.gmail.com"
      SMTP_PORT: "587"
      SMTP_USER: ""
      SMTP_PASSWORD: ""
      SMTP_FROM: ""
      SMTP_FROM_NAME: "CRM Platform"
      SMTP_TLS: "true"

      # Superadmin seed (optional)
      SUPERADMIN_EMAIL: ""
      SUPERADMIN_PASSWORD: ""

  # --- Backend (bootstrap) ---
  # Этот сервис существует и в dev, и в prod. Держим те же креды, что и у api.
  bootstrap:
    environment:
      POSTGRES_USER: "CHANGE_ME_DB_USER"
      POSTGRES_PASSWORD: "CHANGE_ME_DB_PASSWORD"
      POSTGRES_DB: "crm_db"
      DATABASE_URL: "postgresql+asyncpg://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@db:5432/crm_db"
      DATABASE_URL_SYNC: "postgresql+psycopg2://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@db:5432/crm_db"
      REDIS_URL: "redis://redis:6379/0"
      RABBITMQ_USER: "CHANGE_ME_RABBIT_USER"
      RABBITMQ_PASS: "CHANGE_ME_RABBIT_PASSWORD"
      RABBITMQ_URL: "amqp://CHANGE_ME_RABBIT_USER:CHANGE_ME_RABBIT_PASSWORD@rabbitmq:5672/"
      S3_ENDPOINT: "http://minio:9000"
      S3_ACCESS_KEY: "CHANGE_ME_S3_ACCESS_KEY"
      S3_SECRET_KEY: "CHANGE_ME_S3_SECRET_KEY"
      S3_BUCKET: "crm-files"
      S3_REGION: "us-east-1"
      SECRET_KEY: "CHANGE_ME_SECRET_KEY_MIN_32"
      DEBUG: "true"
      LOG_LEVEL: "INFO"
      ENVIRONMENT: "development"

  # --- Celery (dev) ---
  # В prod сервисов celery нет. В dev они запускаются через profile `dev`.
  celery_worker:
    profiles: ["dev"]
    environment:
      POSTGRES_USER: "CHANGE_ME_DB_USER"
      POSTGRES_PASSWORD: "CHANGE_ME_DB_PASSWORD"
      POSTGRES_DB: "crm_db"
      DATABASE_URL: "postgresql+asyncpg://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@db:5432/crm_db"
      DATABASE_URL_SYNC: "postgresql+psycopg2://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@db:5432/crm_db"
      REDIS_URL: "redis://redis:6379/0"
      RABBITMQ_USER: "CHANGE_ME_RABBIT_USER"
      RABBITMQ_PASS: "CHANGE_ME_RABBIT_PASSWORD"
      RABBITMQ_URL: "amqp://CHANGE_ME_RABBIT_USER:CHANGE_ME_RABBIT_PASSWORD@rabbitmq:5672/"
      S3_ENDPOINT: "http://minio:9000"
      S3_ACCESS_KEY: "CHANGE_ME_S3_ACCESS_KEY"
      S3_SECRET_KEY: "CHANGE_ME_S3_SECRET_KEY"
      S3_BUCKET: "crm-files"
      S3_REGION: "us-east-1"
      SECRET_KEY: "CHANGE_ME_SECRET_KEY_MIN_32"
      DEBUG: "true"
      LOG_LEVEL: "INFO"
      ENVIRONMENT: "development"

  celery_beat:
    profiles: ["dev"]
    environment:
      POSTGRES_USER: "CHANGE_ME_DB_USER"
      POSTGRES_PASSWORD: "CHANGE_ME_DB_PASSWORD"
      POSTGRES_DB: "crm_db"
      DATABASE_URL: "postgresql+asyncpg://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@db:5432/crm_db"
      DATABASE_URL_SYNC: "postgresql+psycopg2://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@db:5432/crm_db"
      REDIS_URL: "redis://redis:6379/0"
      RABBITMQ_USER: "CHANGE_ME_RABBIT_USER"
      RABBITMQ_PASS: "CHANGE_ME_RABBIT_PASSWORD"
      RABBITMQ_URL: "amqp://CHANGE_ME_RABBIT_USER:CHANGE_ME_RABBIT_PASSWORD@rabbitmq:5672/"
      S3_ENDPOINT: "http://minio:9000"
      S3_ACCESS_KEY: "CHANGE_ME_S3_ACCESS_KEY"
      S3_SECRET_KEY: "CHANGE_ME_S3_SECRET_KEY"
      S3_BUCKET: "crm-files"
      S3_REGION: "us-east-1"
      SECRET_KEY: "CHANGE_ME_SECRET_KEY_MIN_32"
      DEBUG: "true"
      LOG_LEVEL: "INFO"
      ENVIRONMENT: "development"
  # Celery (dev) использует те же переменные, что и API.
  # Важно: в `docker-compose.prod.yml` сервисов celery нет, поэтому в этом файле
  # мы НЕ описываем `celery_worker`/`celery_beat`, чтобы `secrets.yml` можно было
  # использовать и для dev, и для prod.
  #
  # Если нужно прокинуть секреты в celery в dev:
  # - заполни их в `backend/.env` (dev compose уже читает `env_file: ./backend/.env`)
  # - или сделаем отдельный `secrets.dev.yml` (только для dev) по твоей команде
  # --- Monitoring ---
  grafana:
    environment:
      # Для унификации с docker-compose
      GRAFANA_USER: "CHANGE_ME_GRAFANA_USER"
      # DEV default
      GRAFANA_PASSWORD: "CHANGE_ME_GRAFANA_PASSWORD"
      # Реальные переменные Grafana
      GF_SECURITY_ADMIN_USER: "CHANGE_ME_GRAFANA_USER"
      GF_SECURITY_ADMIN_PASSWORD: "CHANGE_ME_GRAFANA_PASSWORD"
